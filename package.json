{
  "name": "mandal-management-system",
  "version": "1.0.0",
  "description": "Mandal management SaaS platform built with SAP CAP, Supabase Auth, and PostgreSQL.",
  "repository": "https://github.com/Jineshwar-Yuva-Mandal/mandal-management-system",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@cap-js/postgres": "^2.2.0",
    "@sap/cds": "^9",
    "@supabase/supabase-js": "^2.99.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.13.0",
    "@sap/cds-dk": "^9"
  },
  "scripts": {
    "deploy": "mv db/data db/_data_bak && NODE_ENV=production cds deploy --to postgres; mv db/_data_bak db/data",
    "deploy:initial": "NODE_ENV=production cds deploy --to postgres",
    "deploy:test": "cds deploy --to postgres",
    "build": "npm install && npm run deploy:test",
    "build:production": "npm install && cds build --production",
    "start": "cds-serve",
    "start:production": "NODE_ENV=production cds-serve",
    "lint": "npx eslint .",
    "watch-members": "cds watch --open admin/members/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-eventsandattendance": "cds watch --open admin/eventsandattendance/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-fines": "cds watch --open admin/fines/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-ledger": "cds watch --open admin/ledger/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-courses": "cds watch --open admin/courses/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-joinrequests": "cds watch --open admin/joinrequests/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-positions": "cds watch --open admin/positions/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-mandal": "cds watch --open admin/mandal/webapp/index.html?sap-ui-xx-viewCache=false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "postgres",
        "impl": "@cap-js/postgres",
        "pool": {
          "acquireTimeoutMillis": 30000
        },
        "[production]": {
          "schema_evolution": "auto"
        }
      },
      "auth": {
        "impl": "./srv/auth.js"
      }
    }
  },
  "sapux": [
    "app/admin/members",
    "app/admin/eventsandattendance",
    "app/admin/fines",
    "app/admin/ledger",
    "app/admin/courses",
    "app/admin/joinrequests",
    "app/admin/positions",
    "app/admin/mandal"
  ]
}
