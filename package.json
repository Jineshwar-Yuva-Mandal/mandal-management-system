{
  "name": "mandal-management-system",
  "version": "1.0.0",
  "description": "A simple CAP project.",
  "repository": "<Add your repository here>",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9",
    "@cap-js/sqlite": "^2",
    "express": "^4"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.13.0"
  },
  "scripts": {
    "build": "npm install && npx cds deploy --to sqlite:db/samanvay.db",
    "start": "cds-serve",
    "watch-members": "cds watch --open admin/members/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-eventsandattendance": "cds watch --open admin/eventsandattendance/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-fines": "cds watch --open admin/fines/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-ledger": "cds watch --open admin/ledger/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-courses": "cds watch --open admin/courses/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-joinrequests": "cds watch --open admin/joinrequests/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-positions": "cds watch --open admin/positions/webapp/index.html?sap-ui-xx-viewCache=false",
    "watch-mandal": "cds watch --open admin/mandal/webapp/index.html?sap-ui-xx-viewCache=false"
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db/samanvay.db"
        }
      },
      "auth": {
        "kind": "dummy"
      }
    }
  },
  "sapux": [
    "app/admin/members",
    "app/admin/eventsandattendance",
    "app/admin/fines",
    "app/admin/ledger",
    "app/admin/courses",
    "app/admin/joinrequests",
    "app/admin/positions",
    "app/admin/mandal"
  ]
}
