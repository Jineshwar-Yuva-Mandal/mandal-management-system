{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.samanvay.member.courseassignments",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.15.7",
      "toolsId": "72218a10-09c5-49f9-a437-dde71e26ef14"
    },
    "dataSources": {
      "mainService": {
        "uri": "/api/member/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.samanvay.member.courseassignments.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "MyCourseAssignmentsList",
          "target": "MyCourseAssignmentsList"
        },
        {
          "pattern": "MyCourseAssignments({key}):?query:",
          "name": "MyCourseAssignmentsObjectPage",
          "target": "MyCourseAssignmentsObjectPage"
        }
      ],
      "targets": {
        "MyCourseAssignmentsList": {
          "type": "Component",
          "id": "MyCourseAssignmentsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/MyCourseAssignments",
              "variantManagement": "Page",
              "navigation": {
                "MyCourseAssignments": {
                  "detail": {
                    "route": "MyCourseAssignmentsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "columns": {
                    "DataField::course::title": {
                      "availability": "Default",
                      "width": "30%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::status": {
                      "availability": "Default",
                      "width": "15%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::completion_pct": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::assigned_date": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::due_date": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::completed_date": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::assigned_by::full_name": {
                      "availability": "Default",
                      "width": "15%",
                      "widthIncludingColumnHeader": true
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "MyCourseAssignmentsObjectPage": {
          "type": "Component",
          "id": "MyCourseAssignmentsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/MyCourseAssignments",
              "controlConfiguration": {
                "progress/@com.sap.vocabularies.UI.v1.LineItem#TopicProgress": {
                  "columns": {
                    "DataField::topic::title": {
                      "availability": "Default",
                      "width": "30%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::remarks": {
                      "width": "35%",
                      "availability": "Default",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::topic::sequence": {
                      "availability": "Default",
                      "width": "5%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::status": {
                      "availability": "Default",
                      "width": "15%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::completed_date": {
                      "availability": "Default",
                      "width": "15%",
                      "widthIncludingColumnHeader": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
