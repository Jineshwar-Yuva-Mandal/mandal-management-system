{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.samanvay.member.mandalevents",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.15.7",
      "toolsId": "c8542635-294b-4470-964d-0db6b7e87efe"
    },
    "dataSources": {
      "mainService": {
        "uri": "/api/member/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.samanvay.member.mandalevents.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "MandalEventsList",
          "target": "MandalEventsList"
        },
        {
          "pattern": "MandalEvents({key}):?query:",
          "name": "MandalEventsObjectPage",
          "target": "MandalEventsObjectPage"
        }
      ],
      "targets": {
        "MandalEventsList": {
          "type": "Component",
          "id": "MandalEventsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/MandalEvents",
              "variantManagement": "Page",
              "navigation": {
                "MandalEvents": {
                  "detail": {
                    "route": "MandalEventsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  },
                  "columns": {
                    "DataField::title": {
                      "availability": "Default",
                      "width": "40%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::event_date": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::start_time": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::end_time": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::location": {
                      "availability": "Default",
                      "width": "20%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::has_fine": {
                      "availability": "Default",
                      "width": "10%"
                    },
                    "DataField::attendance::rsvp_status": {
                      "availability": "Default",
                      "width": "5%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::attendance::status": {
                      "width": "5%",
                      "widthIncludingColumnHeader": true
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "MandalEventsObjectPage": {
          "type": "Component",
          "id": "MandalEventsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/MandalEvents",
              "controlConfiguration": {
                "attendance/@com.sap.vocabularies.UI.v1.LineItem#EventAttendance": {
                  "columns": {
                    "DataField::user::full_name": {
                      "availability": "Default",
                      "width": "30%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::rsvp_status": {
                      "availability": "Default",
                      "width": "15%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::status": {
                      "availability": "Default",
                      "width": "20%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::remarks": {
                      "availability": "Default",
                      "width": "40%",
                      "widthIncludingColumnHeader": true
                    }
                  }
                }
              },
              "content": {
                "header": {
                  "actions": {
                    "DataFieldForAction::MemberService.rsvpYes": {
                      "priority": "High",
                      "afterExecution": {
                        "navigateToInstance": false
                      }
                    },
                    "DataFieldForAction::MemberService.rsvpNo": {
                      "priority": "High",
                      "afterExecution": {
                        "navigateToInstance": false
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
