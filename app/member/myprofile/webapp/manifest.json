{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.samanvay.member.myprofile",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.15.7",
      "toolsId": "d95ee4b8-b8d7-40aa-81bf-137df28340cc"
    },
    "dataSources": {
      "mainService": {
        "uri": "/api/member/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.0"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.samanvay.member.myprofile.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "MyProfileList",
          "target": "MyProfileList"
        },
        {
          "pattern": "MyProfile({key}):?query:",
          "name": "MyProfileObjectPage",
          "target": "MyProfileObjectPage"
        }
      ],
      "targets": {
        "MyProfileList": {
          "type": "Component",
          "id": "MyProfileList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/MyProfile",
              "variantManagement": "Page",
              "navigation": {
                "MyProfile": {
                  "detail": {
                    "route": "MyProfileObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "MyProfileObjectPage": {
          "type": "Component",
          "id": "MyProfileObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": false,
              "contextPath": "/MyProfile",
              "controlConfiguration": {
                "memberships/@com.sap.vocabularies.UI.v1.LineItem#MyMemberships": {
                  "columns": {
                    "DataField::joined_date": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::membership_status": {
                      "availability": "Default",
                      "width": "10%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::mandal::area": {
                      "availability": "Default",
                      "width": "35%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::mandal::name": {
                      "availability": "Default",
                      "width": "45%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::mandal::logo": {
                      "availability": "Default",
                      "width": "5%",
                      "widthIncludingColumnHeader": true
                    }
                  }
                },
                "positionAssignments/@com.sap.vocabularies.UI.v1.LineItem#MyPositions": {
                  "columns": {
                    "DataField::position::name": {
                      "width": "35%",
                      "widthIncludingColumnHeader": true,
                      "availability": "Default"
                    },
                    "DataField::mandal::name": {
                      "availability": "Default",
                      "width": "45%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::valid_from": {
                      "availability": "Default",
                      "width": "20%",
                      "widthIncludingColumnHeader": true
                    },
                    "DataField::valid_to": {
                      "availability": "Default",
                      "width": "20%",
                      "widthIncludingColumnHeader": true
                    }
                  }
                }
              },
              "content": {
                "header": {
                  "visible": true
                }
              },
              "enableLazyLoading": true
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  }
}
