{
    "_version": "1.65.0",
    "sap.app": {
        "id": "com.samanvay.admin.members",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:lrop",
            "version": "1.15.7",
            "toolsId": "55642c2a-7e97-455b-9809-fbfb82d01d67"
        },
        "dataSources": {
            "mainService": {
                "uri": "/api/admin/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "odataVersion": "4.0"
                }
            }
        },
        "crossNavigation": {
            "inbounds": {
                "Member-manage": {
                    "semanticObject": "Member",
                    "action": "manage",
                    "title": "{{flpTitle}}",
                    "subTitle": "{{flpSubtitle}}",
                    "signature": {
                        "parameters": {},
                        "additionalParameters": "allowed"
                    },
                    "icon": "sap-icon://group"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.145.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.fe.templates": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.samanvay.admin.members.i18n.i18n"
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            },
            "@i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "uri": "i18n/i18n.properties"
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {},
            "routes": [
                {
                    "pattern": ":?query:",
                    "name": "MembersList",
                    "target": "MembersList"
                },
                {
                    "pattern": "Members({key}):?query:",
                    "name": "MembersObjectPage",
                    "target": "MembersObjectPage"
                }
            ],
            "targets": {
                "MembersList": {
                    "type": "Component",
                    "id": "MembersList",
                    "name": "sap.fe.templates.ListReport",
                    "options": {
                        "settings": {
                            "contextPath": "/Members",
                            "variantManagement": "None",
                            "navigation": {
                                "Members": {
                                    "detail": {
                                        "route": "MembersObjectPage"
                                    }
                                }
                            },
                            "controlConfiguration": {
                                "@com.sap.vocabularies.UI.v1.LineItem": {
                                    "tableSettings": {
                                        "type": "ResponsiveTable",
                                        "header": "Members",
                                        "selectAll": false,
                                        "selectionMode": "None",
                                        "widthIncludingColumnHeader": true,
                                        "quickVariantSelection": {
                                            "hideTableTitle": false,
                                            "showCounts": true
                                        },
                                        "personalization": {
                                            "sort": true,
                                            "filter": true,
                                            "column": true
                                        },
                                        "disableCopyToClipboard": true,
                                        "enableExport": true,
                                        "enableMassEdit": false
                                    },
                                    "columns": {
                                        "DataField::profile_picture": {
                                            "availability": "Default",
                                            "widthIncludingColumnHeader": true,
                                            "width": "5%"
                                        },
                                        "DataField::email": {
                                            "availability": "Default",
                                            "width": "15%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::full_name": {
                                            "availability": "Default",
                                            "width": "15%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::phone": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::dob": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::education": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::gotra": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::profession": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::father_name": {
                                            "width": "15%",
                                            "widthIncludingColumnHeader": true
                                        }
                                    }
                                }
                            },
                            "hideFilterBar": false,
                            "initialLoad": "Enabled"
                        }
                    }
                },
                "MembersObjectPage": {
                    "type": "Component",
                    "id": "MembersObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "editableHeaderContent": false,
                            "contextPath": "/Members",
                            "sectionLayout": "Page",
                            "content": {
                                "header": {
                                    "anchorBarVisible": true,
                                    "visible": true
                                }
                            },
                            "controlConfiguration": {
                                "memberships/@com.sap.vocabularies.UI.v1.LineItem#i18nMemberships": {
                                    "tableSettings": {
                                        "enableExport": true,
                                        "disableCopyToClipboard": true,
                                        "selectAll": false,
                                        "selectionMode": "None",
                                        "type": "ResponsiveTable",
                                        "widthIncludingColumnHeader": true,
                                        "personalization": {
                                            "column": true,
                                            "filter": true,
                                            "sort": true
                                        },
                                        "quickVariantSelection": {
                                            "hideTableTitle": false,
                                            "showCounts": true
                                        }
                                    },
                                    "columns": {
                                        "DataField::mandal::name": {
                                            "availability": "Default",
                                            "width": "20%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::mandal::area": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::mandal::state": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::joined_date": {
                                            "availability": "Default",
                                            "width": "8%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::left_date": {
                                            "availability": "Default",
                                            "width": "8%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::remarks": {
                                            "availability": "Default",
                                            "width": "19%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::mandal::logo": {
                                            "availability": "Default",
                                            "width": "5%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::user::city": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::membership_status": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "sap.fiori": {
        "registrationIds": [],
        "archeType": "transactional"
    }
}