{
    "_version": "1.65.0",
    "sap.app": {
        "id": "com.samanvay.admin.mandal",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:lrop",
            "version": "1.15.7",
            "toolsId": "ebdb7b5d-10ad-4a52-ba92-1f04b38a7a6b"
        },
        "dataSources": {
            "mainService": {
                "uri": "/api/admin/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "odataVersion": "4.0"
                }
            }
        },
        "crossNavigation": {
            "inbounds": {
                "MandalSettings-manage": {
                    "semanticObject": "MandalSettings",
                    "action": "manage",
                    "title": "{{flpTitle}}",
                    "subTitle": "{{flpSubtitle}}",
                    "signature": {
                        "parameters": {},
                        "additionalParameters": "allowed"
                    },
                    "icon": "sap-icon://action-settings"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "dependencies": {
            "minUI5Version": "1.145.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.fe.templates": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.samanvay.admin.mandal.i18n.i18n",
                    "supportedLocales": [""],
                    "fallbackLocale": ""
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            },
            "@i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "uri": "i18n/i18n.properties",
                "settings": {
                    "supportedLocales": [""],
                    "fallbackLocale": ""
                }
            }
        },
        "resources": {
            "css": []
        },
        "routing": {
            "config": {},
            "routes": [
                {
                    "pattern": ":?query:",
                    "name": "MandalList",
                    "target": "MandalList"
                },
                {
                    "pattern": "Mandal({key}):?query:",
                    "name": "MandalObjectPage",
                    "target": "MandalObjectPage"
                },
                {
                    "pattern": "Mandal({key})/fieldConfigs({key2}):?query:",
                    "name": "FieldConfigObjectPage",
                    "target": "FieldConfigObjectPage"
                }
            ],
            "targets": {
                "MandalList": {
                    "type": "Component",
                    "id": "MandalList",
                    "name": "sap.fe.templates.ListReport",
                    "options": {
                        "settings": {
                            "contextPath": "/Mandal",
                            "variantManagement": "Page",
                            "navigation": {
                                "Mandal": {
                                    "detail": {
                                        "route": "MandalObjectPage"
                                    }
                                }
                            },
                            "controlConfiguration": {
                                "@com.sap.vocabularies.UI.v1.LineItem": {
                                    "tableSettings": {
                                        "type": "ResponsiveTable"
                                    }
                                }
                            }
                        }
                    }
                },
                "MandalObjectPage": {
                    "type": "Component",
                    "id": "MandalObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "editableHeaderContent": false,
                            "contextPath": "/Mandal",
                            "navigation": {
                                "fieldConfigs": {
                                    "detail": {
                                        "route": "FieldConfigObjectPage"
                                    }
                                }
                            },
                            "controlConfiguration": {
                                "fieldConfigs/@com.sap.vocabularies.UI.v1.LineItem#FieldConfig": {
                                    "tableSettings": {
                                        "type": "ResponsiveTable",
                                        "creationMode": {
                                            "name": "Inline"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "FieldConfigObjectPage": {
                    "type": "Component",
                    "id": "FieldConfigObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "editableHeaderContent": false,
                            "contextPath": "/Mandal/fieldConfigs"
                        }
                    }
                }
            }
        }
    },
    "sap.fiori": {
        "registrationIds": [],
        "archeType": "transactional"
    }
}