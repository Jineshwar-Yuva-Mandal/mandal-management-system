{
    "_version": "1.65.0",
    "sap.app": {
        "id": "com.samanvay.admin.joinrequests",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:lrop",
            "version": "1.15.7",
            "toolsId": "5c68ebdd-3432-4648-8932-fb70a4598a9c"
        },
        "dataSources": {
            "mainService": {
                "uri": "/api/admin/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "odataVersion": "4.0"
                }
            }
        },
        "crossNavigation": {
            "inbounds": {
                "MembershipRequest-manage": {
                    "semanticObject": "MembershipRequest",
                    "action": "manage",
                    "title": "{{flpTitle}}",
                    "subTitle": "{{flpSubtitle}}",
                    "signature": {
                        "parameters": {},
                        "additionalParameters": "allowed"
                    },
                    "icon": "sap-icon://add-employee"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": false,
        "dependencies": {
            "minUI5Version": "1.145.0",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.fe.templates": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "com.samanvay.admin.joinrequests.i18n.i18n",
                    "supportedLocales": [
                        ""
                    ],
                    "fallbackLocale": ""
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {
                    "operationMode": "Server",
                    "autoExpandSelect": true,
                    "earlyRequests": true
                }
            },
            "@i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "uri": "i18n/i18n.properties",
                "settings": {
                    "supportedLocales": [
                        ""
                    ],
                    "fallbackLocale": ""
                }
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {},
            "routes": [
                {
                    "pattern": ":?query:",
                    "name": "JoinRequestsList",
                    "target": "JoinRequestsList"
                },
                {
                    "pattern": "JoinRequests({key}):?query:",
                    "name": "JoinRequestsObjectPage",
                    "target": "JoinRequestsObjectPage"
                }
            ],
            "targets": {
                "JoinRequestsList": {
                    "type": "Component",
                    "id": "JoinRequestsList",
                    "name": "sap.fe.templates.ListReport",
                    "options": {
                        "settings": {
                            "contextPath": "/JoinRequests",
                            "variantManagement": "Page",
                            "navigation": {
                                "JoinRequests": {
                                    "detail": {
                                        "route": "JoinRequestsObjectPage"
                                    }
                                }
                            },
                            "controlConfiguration": {
                                "@com.sap.vocabularies.UI.v1.LineItem": {
                                    "tableSettings": {
                                        "type": "ResponsiveTable"
                                    },
                                    "columns": {
                                        "DataField::requester_name": {
                                            "availability": "Default",
                                            "width": "13%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::requester_email": {
                                            "availability": "Default",
                                            "width": "17%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::requester_phone": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::status": {
                                            "availability": "Default",
                                            "width": "10%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::paid_amount": {
                                            "availability": "Default",
                                            "width": "8%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::paid_date": {
                                            "availability": "Default",
                                            "width": "9%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::payment_verified_by::full_name": {
                                            "availability": "Default",
                                            "width": "13%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::payment_verified": {
                                            "availability": "Default",
                                            "width": "8%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::user::profile_picture": {
                                            "availability": "Default",
                                            "width": "6%",
                                            "widthIncludingColumnHeader": true
                                        },
                                        "DataField::payment_verified_by::profile_picture": {
                                            "availability": "Default",
                                            "width": "6%",
                                            "widthIncludingColumnHeader": true
                                        }
                                    }
                                }
                            },
                            "initialLoad": "Enabled"
                        }
                    }
                },
                "JoinRequestsObjectPage": {
                    "type": "Component",
                    "id": "JoinRequestsObjectPage",
                    "name": "sap.fe.templates.ObjectPage",
                    "options": {
                        "settings": {
                            "editableHeaderContent": false,
                            "contextPath": "/JoinRequests"
                        }
                    }
                }
            }
        }
    },
    "sap.fiori": {
        "registrationIds": [],
        "archeType": "transactional"
    }
}