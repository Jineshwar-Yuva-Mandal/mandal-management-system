<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
    xmlns:f="sap.ui.layout.form">

    <VBox class="samanvayAuthPage" alignItems="Center" justifyContent="Center">
        <VBox class="samanvayAuthCard">

            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                <Button icon="sap-icon://nav-back" type="Transparent" press=".onBackToOnboarding"
                        class="sapUiTinyMarginEnd"/>
                <Title text="Create a New Mandal" level="H3" titleStyle="H4"/>
            </HBox>

            <Text text="Fill in the details below to set up your mandal. You'll become its administrator."
                  class="sapUiSmallMarginBottom samanvaySubtitle"/>

            <!-- Error message -->
            <MessageStrip
                text="{/createMandal/errorMessage}"
                type="Error"
                showIcon="true"
                visible="{= !!${/createMandal/errorMessage} }"
                class="sapUiSmallMarginBottom"/>

            <f:SimpleForm editable="true" layout="ResponsiveGridLayout"
                          labelSpanXL="3" labelSpanL="3" labelSpanM="3" labelSpanS="12"
                          emptySpanXL="0" emptySpanL="0" emptySpanM="0"
                          columnsXL="1" columnsL="1" columnsM="1">

                <Label text="Mandal Name" required="true"/>
                <Input value="{/createMandal/name}" placeholder="e.g. Jineshwar Yuva Mandal"/>

                <Label text="Area / Locality"/>
                <Input value="{/createMandal/area}" placeholder="e.g. Matunga"/>

                <Label text="City" required="true"/>
                <Input value="{/createMandal/city}" placeholder="e.g. Mumbai"/>

                <Label text="State" required="true"/>
                <Input value="{/createMandal/state}" placeholder="e.g. Maharashtra"/>

            </f:SimpleForm>

            <Button text="Create Mandal"
                type="Emphasized"
                width="100%"
                press=".onCreateMandalSubmit"
                busy="{/createMandal/busy}"
                class="sapUiMediumMarginTop samanvayAuthInput"/>

        </VBox>
    </VBox>

</core:FragmentDefinition>
