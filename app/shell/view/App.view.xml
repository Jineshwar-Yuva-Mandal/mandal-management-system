<mvc:View
    controllerName="com.samanvay.shell.controller.App"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:f="sap.f"
    xmlns:tnt="sap.tnt"
    xmlns:core="sap.ui.core"
    height="100%">

    <tnt:ToolPage id="toolPage" sideExpanded="false">

        <!-- ── Header: ShellBar ── -->
        <tnt:header>
            <f:ShellBar
                title="Samanvay"
                secondTitle="Mandal Management System"
                homeIcon="./logo.png"
                showMenuButton="true"
                menuButtonPressed=".onMenuButtonPress"
                homeIconPressed=".onHomePress"
                avatarPressed=".onAvatarPress">
                <f:profile>
                    <Avatar initials="{/profile/initials}" displaySize="XS" backgroundColor="Accent6"/>
                </f:profile>
            </f:ShellBar>
        </tnt:header>

        <!-- ── Side Navigation (tree-based) ── -->
        <tnt:sideContent>
            <tnt:SideNavigation id="sideNav" expanded="false" itemSelect=".onNavItemSelect">
                <tnt:item>
                    <tnt:NavigationList>
                        <!-- Admin group -->
                        <tnt:NavigationListItem text="Admin" icon="sap-icon://shield" expanded="true">
                            <tnt:NavigationListItem text="Members" icon="sap-icon://group" key="admin/members/webapp/index.html"/>
                            <tnt:NavigationListItem text="Join Requests" icon="sap-icon://add-employee" key="admin/joinrequests/webapp/index.html"/>
                            <tnt:NavigationListItem text="Positions" icon="sap-icon://org-chart" key="admin/positions/webapp/index.html"/>
                            <tnt:NavigationListItem text="Events &amp; Attendance" icon="sap-icon://calendar" key="admin/eventsandattendance/webapp/index.html"/>
                            <tnt:NavigationListItem text="Courses" icon="sap-icon://education" key="admin/courses/webapp/index.html"/>
                            <tnt:NavigationListItem text="Fines" icon="sap-icon://money-bills" key="admin/fines/webapp/index.html"/>
                            <tnt:NavigationListItem text="Financial Ledger" icon="sap-icon://accounting-document-verification" key="admin/ledger/webapp/index.html"/>
                            <tnt:NavigationListItem text="Mandal Settings" icon="sap-icon://action-settings" key="admin/mandal/webapp/index.html"/>
                        </tnt:NavigationListItem>
                        <!-- Member group -->
                        <tnt:NavigationListItem text="Member" icon="sap-icon://person-placeholder">
                            <tnt:NavigationListItem text="My Profile" icon="sap-icon://account" key="#member-profile"/>
                            <tnt:NavigationListItem text="My Mandals" icon="sap-icon://building" key="#member-mandals"/>
                            <tnt:NavigationListItem text="Events" icon="sap-icon://appointment" key="#member-events"/>
                            <tnt:NavigationListItem text="My Courses" icon="sap-icon://curriculum" key="#member-courses"/>
                            <tnt:NavigationListItem text="My Fines" icon="sap-icon://money-bills" key="#member-fines"/>
                            <tnt:NavigationListItem text="Member Directory" icon="sap-icon://contacts" key="#member-directory"/>
                            <tnt:NavigationListItem text="Ledger" icon="sap-icon://monitor-payments" key="#member-ledger"/>
                        </tnt:NavigationListItem>
                    </tnt:NavigationList>
                </tnt:item>
                <tnt:fixedItem>
                    <tnt:NavigationList itemSelect=".onFixedNavItemSelect">
                        <tnt:NavigationListItem text="UI5 Docs" icon="sap-icon://learning-assistant" key="https://ui5.sap.com"/>
                        <tnt:NavigationListItem text="CAP Docs" icon="sap-icon://course-book" key="https://cap.cloud.sap/docs/"/>
                        <tnt:NavigationListItem text="Contact Us" icon="sap-icon://email" key="mailto:jymdigital@samanvay.org"/>
                        <tnt:NavigationListItem text="Raise an Issue" icon="sap-icon://alert" key="https://github.com/Jineshwar-Yuva-Mandal/mandal-management-system/issues"/>
                    </tnt:NavigationList>
                </tnt:fixedItem>
            </tnt:SideNavigation>
        </tnt:sideContent>

        <!-- ── Main Content Area ── -->
        <tnt:mainContents>
            <NavContainer id="navContainer" height="100%">
                <Page id="welcomePage" showHeader="false" enableScrolling="true">
                    <core:Fragment fragmentName="com.samanvay.shell.view.Welcome" type="XML"/>
                    <footer>
                        <core:Fragment fragmentName="com.samanvay.shell.view.Footer" type="XML"/>
                    </footer>
                </Page>
                <Page id="appPage" title="{/appTitle}" showNavButton="true" navButtonPress=".onHomePress"
                      enableScrolling="false" class="samanvayAppPage">
                    <core:HTML id="appFrame" sanitizeContent="false"/>
                </Page>
            </NavContainer>
        </tnt:mainContents>

    </tnt:ToolPage>

</mvc:View>
