<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core">
    <Popover id="profilePopover" placement="Bottom" showHeader="false" contentWidth="16rem">
        <VBox class="sapUiSmallMargin">
            <HBox alignItems="Center" class="sapUiSmallMarginBottom">
                <Avatar initials="{/profile/initials}" displaySize="S" backgroundColor="Accent6"
                        class="sapUiSmallMarginEnd"/>
                <VBox>
                    <Title text="{/profile/name}" level="H6"/>
                    <Label text="{/profile/role}" design="Standard"/>
                </VBox>
            </HBox>
            <VBox>
                <Button text="My Profile" icon="sap-icon://account" type="Transparent"
                        width="100%" press=".onProfileMenuAction" class="samanvayProfileBtn">
                    <customData>
                        <core:CustomData key="action" value="profile"/>
                    </customData>
                </Button>
                <Button text="Settings" icon="sap-icon://action-settings" type="Transparent"
                        width="100%" press=".onProfileMenuAction" class="samanvayProfileBtn">
                    <customData>
                        <core:CustomData key="action" value="settings"/>
                    </customData>
                </Button>
                <Button text="Sign Out" icon="sap-icon://log" type="Transparent"
                        width="100%" press=".onProfileMenuAction" class="samanvayProfileBtn">
                    <customData>
                        <core:CustomData key="action" value="signout"/>
                    </customData>
                </Button>
            </VBox>
        </VBox>
    </Popover>
</core:FragmentDefinition>
